package com.dataops.dms.workflow;

import com.alibaba.fastjson2.JSON;
import com.dataops.dms.entity.DataChangeBackup;
import com.dataops.dms.entity.DatabaseInstance;
import com.dataops.dms.service.DataBackupService;
import com.dataops.dms.service.DatabaseInstanceService;
import com.dataops.dms.sql.SqlExecutor;
import com.dataops.dms.sql.SqlExecuteResult;
import lombok.extern.slf4j.Slf4j;
import org.flowable.engine.delegate.DelegateExecution;
import org.flowable.engine.delegate.JavaDelegate;
import org.springframework.stereotype.Component;

import javax.annotation.Resource;
import java.sql.Connection;
import java.sql.DriverManager;
import java.sql.Statement;
import java.time.LocalDateTime;

/**
 * SQL执行委托 - Flowable自动任务
 * 审批通过后自动执行SQL变更，执行前自动备份数据
 */
@Slf4j
@Component
public class SqlExecuteDelegate implements JavaDelegate {

    @Resource
    private SqlExecutor sqlExecutor;

    @Resource
    private DatabaseInstanceService databaseInstanceService;

    @Resource
    private DataBackupService dataBackupService;

    @Override
    public void execute(DelegateExecution execution) {
        log.info("========== 开始执行SQL变更工单 ==========");
        log.info("流程实例ID: {}", execution.getProcessInstanceId());
        
        // 获取流程变量
        String ticketId = (String) execution.getVariable("ticketId");
        String databaseId = (String) execution.getVariable("databaseId");
        String sqlContent = (String) execution.getVariable("sqlContent");
        String executorId = (String) execution.getVariable("executorId");

        log.info("工单ID: {}", ticketId);
        log.info("数据库ID: {}", databaseId);
        log.info("执行SQL: {}", sqlContent.substring(0, Math.min(200, sqlContent.length())) + "...");

        Connection conn = null;
        DataChangeBackup backup = null;

        try {
            // 1. 获取数据库实例
            DatabaseInstance db = databaseInstanceService.getById(databaseId);
            if (db == null) {
                throw new RuntimeException("数据库实例不存在: " + databaseId);
            }

            // 2. ====== 执行前自动备份数据 ======
            log.info("步骤1: 开始备份原始数据...");
            backup = dataBackupService.backupBeforeChange(db, ticketId, sqlContent, executorId);
            
            if ("success".equals(backup.getStatus())) {
                log.info("✅ 数据备份成功！备份表: {}, 回滚SQL已生成", backup.getTableName());
                execution.setVariable("backupId", backup.getId());
                execution.setVariable("backupSuccess", true);
                execution.setVariable("rollbackSql", backup.getRollbackSql());
            } else {
                log.warn("⚠️ 数据备份失败: {}，继续执行但不支持自动回滚", backup.getErrorMessage());
                execution.setVariable("backupSuccess", false);
                execution.setVariable("backupError", backup.getErrorMessage());
            }

            // 3. 执行SQL变更
            log.info("步骤2: 开始执行SQL变更...");
            long startTime = System.currentTimeMillis();
            
            String jdbcUrl = buildJdbcUrl(db);
            conn = DriverManager.getConnection(jdbcUrl, db.getUsername(), db.getPassword());
            conn.setAutoCommit(false);  // 开启事务
            
            Statement stmt = conn.createStatement();
            int affectRows = stmt.executeUpdate(sqlContent);
            
            long executionTime = System.currentTimeMillis() - startTime;
            log.info("✅ SQL执行完成，影响行数: {}, 耗时: {}ms", affectRows, executionTime);

            // 4. 提交事务
            conn.commit();
            log.info("✅ 事务已提交");

            // 5. 设置流程结果变量
            execution.setVariable("executeResult", "success");
            execution.setVariable("affectRows", affectRows);
            execution.setVariable("executionTime", executionTime);
            execution.setVariable("executeTime", LocalDateTime.now().toString());

            log.info("========== SQL变更执行成功 ✅ ==========");

        } catch (Exception e) {
            log.error("❌ SQL变更执行失败: {}", e.getMessage(), e);
            
            // 回滚事务
            try {
                if (conn != null && !conn.isClosed()) {
                    conn.rollback();
                    log.info("事务已回滚");
                }
            } catch (Exception rollbackEx) {
                log.error("事务回滚失败: {}", rollbackEx.getMessage());
            }

            execution.setVariable("executeResult", "failed");
            execution.setVariable("errorMessage", e.getMessage());
            throw new RuntimeException("SQL执行失败: " + e.getMessage(), e);
        } finally {
            try {
                if (conn != null && !conn.isClosed()) {
                    conn.close();
                }
            } catch (Exception e) {
                log.warn("关闭连接失败: {}", e.getMessage());
            }
        }
    }

    /**
     * 构建JDBC URL
     */
    private String buildJdbcUrl(DatabaseInstance db) {
        String dbType = db.getDbType().toLowerCase();
        String host = db.getHost();
        int port = db.getPort();
        String database = db.getDatabaseName() != null ? db.getDatabaseName() : "";

        switch (dbType) {
            case "mysql":
                return String.format("jdbc:mysql://%s:%d/%s?useUnicode=true&characterEncoding=utf8&serverTimezone=Asia/Shanghai&useSSL=false&allowPublicKeyRetrieval=true",
                    host, port, database);
            case "postgresql":
                return String.format("jdbc:postgresql://%s:%d/%s", host, port, database);
            default:
                throw new IllegalArgumentException("暂不支持的数据库类型: " + dbType);
        }
    }
}
