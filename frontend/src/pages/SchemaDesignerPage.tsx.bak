import React, { useState, useEffect } from 'react';
import { Card, Button, Input, Select, Modal, Form, Table, message, Space, Row, Col, Tag, Drawer, Divider, Popconfirm, Switch, Collapse, Tabs, Alert, Checkbox, Empty, Spin } from 'antd';
import { PlusOutlined, SaveOutlined, DatabaseOutlined, TableOutlined, KeyOutlined, SettingOutlined, ImportOutlined, ThunderboltOutlined, EditOutlined, ReloadOutlined, DeleteOutlined } from '@ant-design/icons';
import { databaseApi } from '../utils/api';

const { Option } = Select;
const { TextArea } = Input;
const { Panel } = Collapse;
const { TabPane } = Tabs;

const MYSQL_TYPES = ['TINYINT', 'SMALLINT', 'MEDIUMINT', 'INT', 'BIGINT', 'FLOAT', 'DOUBLE', 'DECIMAL', 'CHAR', 'VARCHAR', 'TEXT', 'MEDIUMTEXT', 'LONGTEXT', 'DATE', 'DATETIME', 'TIMESTAMP', 'JSON', 'BOOLEAN', 'ENUM'];
const TABLE_COLORS = ['#1890ff', '#52c41a', '#faad14', '#f5222d', '#722ed1', '#13c2c2', '#eb2f96', '#fa8c16'];
const genId = () => Math.random().toString(36).substring(2, 10);

type ColumnChangeType = 'ADD' | 'MODIFY';

interface ColumnDef {
  id: string;
  name: string;
  type: string;
  length?: number;
  precision?: number;
  scale?: number;
  nullable: boolean;
  primaryKey: boolean;
  autoIncrement: boolean;
  unique: boolean;
  unsigned?: boolean;
  default?: string;
  comment?: string;
  changeType?: ColumnChangeType;
  isNew?: boolean;
}

interface TableDef {
  id: string;
  name: string;
  comment?: string;
  engine?: string;
  charset?: string;
  collation?: string;
  columns: ColumnDef[];
  x: number;
  y: number;
  color: string;
  isNew?: boolean;
  isModified?: boolean;
}

const SchemaDesignerPage: React.FC = () => {
  const [tables, setTables] = useState<TableDef[]>([]);
  const [selectedTable, setSelectedTable] = useState<string | null>(null);
  const [drawerVisible, setDrawerVisible] = useState(false);
  const [editingTable, setEditingTable] = useState<TableDef | null>(null);
  const [sqlModalVisible, setSqlModalVisible] = useState(false);
  const [generatedSql, setGeneratedSql] = useState('');
  const [sqlMode, setSqlMode] = useState<'create' | 'alter'>('create');
  const [importModalVisible, setImportModalVisible] = useState(false);
  const [importSql, setImportSql] = useState('');
  const [editMode, setEditMode] = useState<'design' | 'alter'>('design');
  const [form] = Form.useForm();

  const [databaseList, setDatabaseList] = useState<any[]>([]);
  const [selectedDatabase, setSelectedDatabase] = useState<string>('');
  const [tableList, setTableList] = useState<string[]>([]);
  const [selectedTableNames, setSelectedTableNames] = useState<string[]>([]);
  const [loadingTables, setLoadingTables] = useState(false);
  const [importing, setImporting] = useState(false);
  const [schemaList, setSchemaList] = useState<string[]>([]);
  const [selectedSchema, setSelectedSchema] = useState<string>('');
  const [loadingSchemas, setLoadingSchemas] = useState(false);

  useEffect(() => {
    loadDatabaseList();
  }, []);

  const loadDatabaseList = async () => {
    try {
      const res = await databaseApi.list();
      if (res.data?.data) {
        setDatabaseList(res.data?.data?.records || res.data?.data || []);
      }
    } catch (e) {
      console.error('加载数据库列表失败', e);
    }
  };

  const handleDatabaseChange = async (dbId: string) => {
    setSelectedDatabase(dbId);
    setSelectedTableNames([]);
    if (!dbId) {
      setTableList([]);
      return;
    }
    setLoadingTables(true);
    try {
      const res = await databaseApi.getTableNames(dbId);
      if (res.data?.data) {
        setTableList(res.data?.data);
      }
    } catch (e: any) {
      message.error('加载表列表失败: ' + (e.response?.data?.message || e.message));
      setTableList([]);
    } finally {
      setLoadingTables(false);
    }
  };

  const handleImportFromDatabase = async () => {
    if (!selectedDatabase || selectedTableNames.length === 0) {
      message.warning('请选择数据库和要导入的表');
      return;
    }
    setImporting(true);
    try {
      const res = await databaseApi.batchGetCreateTableSql(selectedDatabase, selectedTableNames);
      if (res.data?.data) {
        const sqlMap = res.data?.data;
        let importedCount = 0;
        Object.values(sqlMap).forEach((sql: any) => {
          const table = parseCreateTableSql(sql as string);
          if (table) {
            setTables((prev: any) => [...prev, table]);
            importedCount++;
          }
        });
        if (importedCount > 0) {
          message.success(`成功导入 ${importedCount} 张表，现在可以修改表结构了`);
        } else {
          message.warning('未解析到有效的表结构');
        }
      }
    } catch (e: any) {
      message.error('导入失败: ' + (e.response?.data?.message || e.message));
    } finally {
      setImporting(false);
    }
  };

  const addTable = () => {
    const newTable: TableDef = {
      id: genId(),
      name: 'table_' + (tables.length + 1),
      comment: '',
      engine: 'InnoDB',
      charset: 'utf8mb4',
      columns: [{ id: genId(), name: 'id', type: 'BIGINT', nullable: false, primaryKey: true, autoIncrement: true, comment: '主键ID', isNew: true }],
      x: 100 + Math.random() * 200,
      y: 100 + Math.random() * 100,
      color: TABLE_COLORS[tables.length % TABLE_COLORS.length],
      isNew: true,
    };
    setTables([...tables, newTable]);
    setSelectedTable(newTable.id);
    setEditingTable(newTable);
    setDrawerVisible(true);
  };

  const parseCreateTableSql = (sql: string): TableDef | null => {
    try {
      const tableNameMatch = sql.match(/CREATE\s+TABLE\s+(?:IF\s+NOT\s+EXISTS\s+)?`?(\w+)`?/i);
      if (!tableNameMatch) return null;
      const name = tableNameMatch[1];
      const columns: ColumnDef[] = [];
      const innerMatch = sql.match(/\(([\s\S]*)\)/);
      if (innerMatch) {
        const columnPart = innerMatch[1];
        const lines = columnPart.split(/,\s*(?=\n|$)/);
        lines.forEach(line => {
          line = line.trim();
          if (line.match(/^(PRIMARY\s+KEY|UNIQUE|KEY|INDEX|CONSTRAINT|FOREIGN)/i)) return;
          const colMatch = line.match(/^(\w+)\s+(\w+)(?:\(([^)]+)\))?(.*)$/i);
          if (colMatch) {
            const [, colName, colType, length, rest] = colMatch;
            columns.push({
              id: genId(), name: colName, type: colType.toUpperCase(),
              length: length && !isNaN(parseInt(length)) ? parseInt(length) : undefined,
              nullable: !rest.match(/NOT\s+NULL/i),
              primaryKey: !!rest.match(/PRIMARY\s+KEY/i),
              autoIncrement: !!rest.match(/AUTO_INCREMENT/i),
              unique: !!rest.match(/UNIQUE/i),
              comment: rest.match(/COMMENT\s+'([^']+)'/i)?.[1] || '',
              default: rest.match(/DEFAULT\s+'([^']+)'/i)?.[1] || undefined,
              isNew: false,
            });
          }
        });
      }
      const engineMatch = sql.match(/ENGINE\s*=\s*(\w+)/i);
      const charsetMatch = sql.match(/CHARSET\s*=\s*(\w+)/i) || sql.match(/DEFAULT\s+CHARSET\s*=\s*(\w+)/i);
      const commentMatch = sql.match(/COMMENT\s*=\s*'([^']+)'/i);
      return {
        id: genId(), name, engine: engineMatch?.[1] || 'InnoDB', charset: charsetMatch?.[1] || 'utf8mb4',
        comment: commentMatch?.[1] || '', columns,
        x: 100 + (tables.length % 3) * 320, y: 100 + Math.floor(tables.length / 3) * 300,
        color: TABLE_COLORS[tables.length % TABLE_COLORS.length], isNew: false,
      };
    } catch (e) {
      console.error('Parse SQL failed:', e);
      return null;
    }
  };

  const handleImportSql = () => {
    const sqlStatements = importSql.split(/;\s*(?=\n|$)/).filter(s => s.trim().toUpperCase().includes('CREATE TABLE'));
    let importedCount = 0;
    sqlStatements.forEach(sql => {
      const table = parseCreateTableSql(sql);
      if (table) {
        setTables(prev => [...prev, table]);
        importedCount++;
      }
    });
    if (importedCount > 0) {
      message.success(`成功导入 ${importedCount} 张表，现在可以修改表结构了`);
      setEditMode('alter');
    } else {
      message.warning('未解析到有效的 CREATE TABLE 语句');
    }
    setImportModalVisible(false);
    setImportSql('');
  };

  const updateTable = (tableId: string, updates: Partial<TableDef>) => {
    setTables(tables.map(t => t.id === tableId ? { ...t, ...updates, isModified: true } : t));
  };

  const addColumn = (tableId: string) => {
    const table = tables.find(t => t.id === tableId);
    if (!table) return;
    const newColumn: ColumnDef = { id: genId(), name: 'column_' + (table.columns.length + 1), type: 'VARCHAR', length: 255, nullable: true, primaryKey: false, autoIncrement: false, unique: false, comment: '', changeType: 'ADD', isNew: true };
    updateTable(tableId, { columns: [...table.columns, newColumn] });
    message.info('已标记为新增字段');
  };

  const markColumnModified = (tableId: string, columnId: string) => {
    const table = tables.find(t => t.id === tableId);
    if (!table) return;
    const column = table.columns.find(c => c.id === columnId);
    if (column?.isNew) { message.info('新增字段无需标记'); return; }
    updateTable(tableId, { columns: table.columns.map(c => c.id === columnId ? { ...c, changeType: 'MODIFY' as ColumnChangeType } : c) });
    message.success('已标记为修改字段');
  };

  const removeColumn = (tableId: string, columnId: string) => {
    const table = tables.find(t => t.id === tableId);
    if (table) {
      updateTable(table.id, {
        columns: table.columns.filter(c => c.id !== columnId)
      });
    }
  };

  const deleteTable = (tableId: string) => {
    setTables(tables.filter(t => t.id !== tableId));
    if (selectedTable === tableId) setDrawerVisible(false);
    message.success('表已从设计中移除');
  };

  const addCommonFields = (tableId: string, type: string) => {
    const table = tables.find(t => t.id === tableId);
    if (!table) return;
    const commonFields: Record<string, ColumnDef[]> = {
      audit: [
        { id: genId(), name: 'created_at', type: 'DATETIME', nullable: false, comment: '创建时间', changeType: 'ADD', isNew: true },
        { id: genId(), name: 'updated_at', type: 'DATETIME', nullable: false, comment: '更新时间', changeType: 'ADD', isNew: true },
        { id: genId(), name: 'created_by', type: 'VARCHAR', length: 64, nullable: true, comment: '创建人', changeType: 'ADD', isNew: true },
        { id: genId(), name: 'updated_by', type: 'VARCHAR', length: 64, nullable: true, comment: '更新人', changeType: 'ADD', isNew: true },
      ],
      logic_delete: [
        { id: genId(), name: 'deleted', type: 'TINYINT', length: 1, nullable: false, default: '0', comment: '删除标记', changeType: 'ADD', isNew: true },
      ],
      tenant: [
        { id: genId(), name: 'tenant_id', type: 'BIGINT', nullable: false, comment: '租户ID', changeType: 'ADD', isNew: true },
      ],
    };
    const fields = commonFields[type] || [];
    if (fields.length > 0) { updateTable(tableId, { columns: [...table.columns, ...fields] }); message.success(`已添加 ${fields.length} 个字段`); }
  };

  const generateColumnDef = (col: ColumnDef): string => {
    let def = '' + col.name + ' ' + col.type;
    if (['VARCHAR', 'CHAR', 'VARBINARY'].includes(col.type) && col.length) def += '(' + col.length + ')';
    if (['DECIMAL', 'FLOAT', 'DOUBLE'].includes(col.type) && col.precision) { def += '(' + col.precision + (col.scale ? ',' + col.scale : '') + ')'; }
    if (col.unsigned && ['TINYINT', 'SMALLINT', 'MEDIUMINT', 'INT', 'BIGINT'].includes(col.type)) def += ' UNSIGNED';
    if (!col.nullable) def += ' NOT NULL';
    if (col.autoIncrement) def += ' AUTO_INCREMENT';
    if (col.default !== undefined && col.default !== '') def += " DEFAULT '" + col.default + "'";
    if (col.comment) def += " COMMENT '" + col.comment + "'";
    return def;
  };

  const generateSQL = () => {
    const lines: string[] = [];
    lines.push('-- ============================================');
    lines.push('-- 数据库表结构设计 SQL');
    lines.push('-- 生成时间: ' + new Date().toLocaleString());
    lines.push('-- ============================================\n');
    if (sqlMode === 'create') {
      tables.forEach(table => {
        lines.push('-- 表: ' + table.name);
        lines.push('DROP TABLE IF EXISTS ' + table.name + ';');
        lines.push('CREATE TABLE ' + table.name + ' (');
        const columnDefs: string[] = [];
        const pkColumns: string[] = [];
        table.columns.forEach(col => {
          columnDefs.push('  ' + generateColumnDef(col));
          if (col.primaryKey) pkColumns.push(col.name);
        });
        lines.push(columnDefs.join(',\n'));
        if (pkColumns.length > 0) lines.push(',\n  PRIMARY KEY (' + pkColumns.join(', ') + ')');
        let tableOpts = ') ENGINE=' + (table.engine || 'InnoDB') + ' DEFAULT CHARSET=' + (table.charset || 'utf8mb4');
        if (table.comment) tableOpts += " COMMENT='" + table.comment + "'";
        lines.push(tableOpts + ';');
        lines.push('');
      });
    } else {
      lines.push('-- ALTER TABLE 变更脚本');
      lines.push('-- ============================================\n');
      let hasChanges = false;
      tables.forEach(table => {
        const changes = table.columns.filter(c => c.changeType);
        if (changes.length === 0 && !table.isNew) return;
        hasChanges = true;
        lines.push('-- ===== ' + table.name + ' =====');
        if (table.isNew) {
          lines.push('-- 新建表');
          lines.push('CREATE TABLE ' + table.name + ' (');
          const columnDefs: string[] = [];
          const pkColumns: string[] = [];
          table.columns.forEach(col => {
            columnDefs.push('  ' + generateColumnDef(col));
            if (col.primaryKey) pkColumns.push(col.name);
          });
          lines.push(columnDefs.join(',\n'));
          if (pkColumns.length > 0) {
            lines.push(',\n  PRIMARY KEY (' + pkColumns.join(', ') + ')');
          }
          lines.push(') ENGINE=' + (table.engine || 'InnoDB') + ' DEFAULT CHARSET=' + (table.charset || 'utf8mb4') + ';');
        } else {
          changes.forEach(col => {
            if (col.changeType === 'ADD') {
              lines.push('ALTER TABLE ' + table.name + ' ADD COLUMN ' + generateColumnDef(col) + ';');
            } else if (col.changeType === 'MODIFY') {
              lines.push('ALTER TABLE ' + table.name + ' MODIFY COLUMN ' + generateColumnDef(col) + ';');
            }
          });
        }
        lines.push('');
      });
      if (!hasChanges) { lines.push('-- 暂无变更内容'); lines.push('-- 请导入已有表后添加字段'); }
    }
    setGeneratedSql(lines.join('\n'));
    setSqlModalVisible(true);
  };

  const keyIconStyle = { color: '#1890ff' as const };

  const columnColumns = [
    {
      title: '字段名',
      dataIndex: 'name',
      width: 130,
      render: (text: string, record: ColumnDef) => (
        <Space>
          {record.primaryKey && <KeyOutlined style={keyIconStyle} />}
          <span>{text}</span>
          {record.changeType === 'ADD' && <Tag color="green" size="small">新增</Tag>}
          {record.changeType === 'MODIFY' && <Tag color="orange" size="small">修改</Tag>}
        </Space>
      ),
    },
    { title: '类型', dataIndex: 'type', width: 90 },
    { title: '长度', dataIndex: 'length', width: 60 },
    { title: '可空', dataIndex: 'nullable', width: 60, render: (v: boolean) => v ? <Tag color="green">是</Tag> : <Tag color="red">否</Tag> },
    { title: '主键', dataIndex: 'primaryKey', width: 60, render: (v: boolean) => v ? <Tag color="blue">PK</Tag> : '' },
    { title: '注释', dataIndex: 'comment', ellipsis: true, width: 140 },
    {
      title: '操作',
      width: 120,
      render: (_: any, record: ColumnDef) => (
        <Space>
          {!record.isNew && !record.changeType && (
            <Button size="small" type="link" onClick={() => markColumnModified(selectedTable!, record.id)}>
              标记修改
            </Button>
          )}
          {record.isNew && (
            <Popconfirm
              title="确定移除此字段？"
              onConfirm={() => removeColumn(selectedTable!, record.id)}
            >
              <Button size="small" type="link" danger>移除</Button>
            </Popconfirm>
          )}
        </Space>
      ),
    },
  ];

  return (
    <div style={{ height: 'calc(100vh - 64px)', display: 'flex', flexDirection: 'column' }}>
      <Card size="small" style={{ borderBottom: 0, borderRadius: 0 }}>
        <Tabs activeKey={editMode} onChange={setEditMode}>
          <TabPane tab={<Space><TableOutlined />全新设计</Space>} key="design" />
          <TabPane tab={<Space><EditOutlined />修改已有表</Space>} key="alter" />
        </Tabs>
        {editMode === 'design' && (
          <Row justify="space-between" align="middle" style={{ marginTop: 8 }}>
            <Col><Space>
              <Button type="primary" icon={<PlusOutlined />} onClick={addTable}>新建表</Button>
              <Button icon={<ImportOutlined />} onClick={() => setImportModalVisible(true)}>从SQL导入</Button>
              <Divider type="vertical" />
              <Button icon={<SaveOutlined />} onClick={() => {
                const design = { tables, version: '1.0' };
                const blob = new Blob([JSON.stringify(design, null, 2)], { type: 'application/json' });
                const url = URL.createObjectURL(blob);
                const a = document.createElement('a');
                a.href = url; a.download = 'schema_' + Date.now() + '.json'; a.click();
                message.success('设计已保存');
              }}>保存设计</Button>
              <Button type="primary" icon={<ThunderboltOutlined />} onClick={() => { setSqlMode('create'); generateSQL(); }}>生成建表 SQL</Button>
            </Space></Col>
          </Row>
        )}
        {editMode === 'alter' && (
          <div>
            <Row justify="space-between" align="middle" style={{ marginTop: 8, marginBottom: 16 }}>
              <Col span={16}><Space size="large">
                <div style={{ display: 'flex', alignItems: 'center', gap: 8 }}>
                  <span style={{ fontWeight: 500 }}>选择数据库实例:</span>
                  <Select placeholder="请选择要修改表所在的数据库" style={{ width: 320 }} value={selectedDatabase || undefined} onChange={handleDatabaseChange} allowClear>
                    {databaseList.map((db: any) => (<Option key={db.id} value={db.id}><Space><DatabaseOutlined />{db.name}<span style={{ color: '#999', fontSize: 12 }}>({db.host}:{db.port}/{db.databaseName})</span></Space></Option>))}
                  </Select>
                </div>
                <Divider type="vertical" />
                <Button type="primary" icon={<ThunderboltOutlined />} onClick={() => { setSqlMode('alter'); generateSQL(); }} disabled={tables.length === 0}>生成变更 SQL</Button>
                <Button icon={<ReloadOutlined />} onClick={() => { setTables([]); setSelectedDatabase(''); setSchemaList([]); setSelectedSchema(''); setTableList([]); setSelectedTableNames([]); }}>清空重置</Button>
              </Space></Col>
              <Col span={8} style={{ textAlign: 'right' }}><Space>
                <Tag color="blue">已加载表: {tables.length}</Tag>
                <Tag color="green">新增字段: {tables.reduce((sum, t) => sum + t.columns.filter(c => c.changeType === 'ADD').length, 0)}</Tag>
                <Tag color="orange">修改字段: {tables.reduce((sum, t) => sum + t.columns.filter(c => c.changeType === 'MODIFY').length, 0)}</Tag>
              </Space></Col>
            </Row>
            {selectedDatabase && selectedSchema && tableList.length > 0 && tables.length === 0 && (
              <Card size="small" title={<Space><span>选择要修改结构的表（支持多选）</span><Button size="small" onClick={() => setSelectedTableNames(tableList)}>全选</Button><Button size="small" onClick={() => setSelectedTableNames([])}>取消全选</Button><Tag color="blue">已选: {selectedTableNames.length}</Tag></Space>} style={{ marginBottom: 16 }} extra={<Button type="primary" onClick={handleImportFromDatabase} loading={importing} disabled={selectedTableNames.length === 0}>导入选中的 {selectedTableNames.length} 张表</Button>}>
                <div style={{ maxHeight: 180, overflow: 'auto' }}><Spin spinning={loadingTables}><Row gutter={[8, 8]}>
                  {tableList.map((tableName: string) => (<Col span={6} key={tableName}><Card size="small" hoverable style={{ cursor: 'pointer', border: selectedTableNames.includes(tableName) ? '2px solid #1890ff' : '1px solid #d9d9d9', background: selectedTableNames.includes(tableName) ? '#e6f7ff' : '#fff' }} onClick={() => { if (selectedTableNames.includes(tableName)) setSelectedTableNames(selectedTableNames.filter(n => n !== tableName)); else setSelectedTableNames([...selectedTableNames, tableName]); }}><Space><TableOutlined style={{ color: '#1890ff' }} /><span style={{ fontSize: 13 }}>{tableName}</span></Space></Card></Col>))}
                </Row></Spin></div>
              </Card>
            )}
          </div>
        )}
      </Card>
      <div style={{ flex: 1, overflow: 'auto', background: '#f5f5f5', backgroundImage: 'radial-gradient(circle, #d9d9d9 1px, transparent 1px)', backgroundSize: '20px 20px', position: 'relative' }} onClick={() => setSelectedTable(null)}>
        <div style={{ position: 'relative', minWidth: '3000px', minHeight: '2000px', padding: 20 }}>
          {tables.map(table => (
            <div key={table.id} onClick={(e) => { e.stopPropagation(); setSelectedTable(table.id); setEditingTable(table); setDrawerVisible(true); }} style={{ position: 'absolute', left: table.x, top: table.y, width: 320, background: '#fff', borderRadius: 8, boxShadow: selectedTable === table.id ? '0 4px 12px rgba(24,144,255,0.4)' : '0 2px 8px rgba(0,0,0,0.15)', border: selectedTable === table.id ? '2px solid ' + table.color : 'none', zIndex: selectedTable === table.id ? 10 : 2, cursor: 'pointer' }}>
              <div style={{ background: table.color, color: '#fff', padding: '10px 12px', borderRadius: '6px 6px 0 0', display: 'flex', justifyContent: 'space-between', alignItems: 'center' }}>
                <Space><TableOutlined /><strong style={{ fontSize: 14 }}>{table.name}</strong>{table.isNew && <Tag color="#fff" style={{ border: '1px solid #fff', color: '#fff', fontSize: 11, padding: '0 4px' }}>新建</Tag>}</Space>
                <Popconfirm title="从设计中移除此表？" onConfirm={(e: any) => { if (e) e.stopPropagation(); deleteTable(table.id); }}><DeleteOutlined style={{ opacity: 0.8 }} onClick={(e) => e.stopPropagation()} /></Popconfirm>
              </div>
              <div style={{ padding: '8px 0' }}>{table.columns.slice(0, 7).map((col: any) => (<div key={col.id} style={{ padding: '4px 12px', fontSize: 12, display: 'flex', justifyContent: 'space-between', borderBottom: '1px solid #f0f0f0' }}><span style={{ display: 'flex', alignItems: 'center', gap: 4 }}>{col.primaryKey && <KeyOutlined style={{ color: table.color, fontSize: 10 }} />}{col.changeType === 'ADD' && <Tag color="green" style={{ padding: '0 3px', fontSize: 10, lineHeight: 1.5 }}>+</Tag>}{col.changeType === 'MODIFY' && <Tag color="orange" style={{ padding: '0 3px', fontSize: 10, lineHeight: 1.5 }}>M</Tag>}{col.name}</span><span style={{ color: '#666' }}>{col.type}</span></div>))}{table.columns.length > 7 && (<div style={{ padding: '4px 12px', fontSize: 11, color: '#999', textAlign: 'center' }}>+{table.columns.length - 7} 个字段...</div>)}</div>
              <div style={{ padding: '8px 12px', fontSize: 11, color: '#999', borderTop: '1px solid #f0f0f0', display: 'flex', justifyContent: 'space-between' }}><span>{table.columns.length} 个字段</span>{table.comment && <span style={{ maxWidth: 180, overflow: 'hidden', textOverflow: 'ellipsis' }}>{table.comment}</span>}</div>
            </div>
          ))}
          {tables.length === 0 && editMode === 'alter' && !selectedDatabase && (<div style={{ position: 'absolute', top: '20%', left: '50%', transform: 'translateX(-50%)', textAlign: 'center', color: '#999', maxWidth: 500 }}><DatabaseOutlined style={{ fontSize: 64, marginBottom: 16 }} /><h3 style={{ marginBottom: 16 }}>请选择数据库实例</h3><Alert message="在上方下拉框中选择要修改表所在的数据库" description="选择数据库后，系统会自动加载库中的所有表，您可以勾选需要修改结构的表进行批量导入" type="info" showIcon /></div>)}
          {tables.length === 0 && editMode === 'alter' && selectedDatabase && tableList.length === 0 && !loadingTables && (<div style={{ position: 'absolute', top: '20%', left: '50%', transform: 'translateX(-50%)', textAlign: 'center', color: '#999' }}><Empty description="该数据库暂无表" /></div>)}
          {tables.length === 0 && editMode === 'design' && (<div style={{ position: 'absolute', top: '30%', left: '50%', transform: 'translateX(-50%)', textAlign: 'center', color: '#999' }}><DatabaseOutlined style={{ fontSize: 64, marginBottom: 16 }} /><p>点击 "新建表" 开始设计数据库表结构</p></div>)}
        </div>
      </div>
      <Drawer title={<Space><SettingOutlined />编辑表结构 - {editingTable?.name}</Space>} placement="right" width={620} open={drawerVisible} onClose={() => setDrawerVisible(false)}>
        {editingTable && (<Collapse defaultActiveKey={['basic', 'columns', 'quick']} ghost>
          <Panel header="基本信息" key="basic"><Form layout="vertical" size="small">
            <Row gutter={16}><Col span={12}><Form.Item label="表名"><Input value={editingTable.name} onChange={(e) => updateTable(editingTable.id, { name: e.target.value })} /></Form.Item></Col><Col span={12}><Form.Item label="存储引擎"><Select value={editingTable.engine} onChange={(v) => updateTable(editingTable.id, { engine: v })}><Option value="InnoDB">InnoDB</Option><Option value="MyISAM">MyISAM</Option></Select></Form.Item></Col></Row>
            <Row gutter={16}><Col span={12}><Form.Item label="字符集"><Input value={editingTable.charset} onChange={(e) => updateTable(editingTable.id, { charset: e.target.value })} /></Form.Item></Col></Row>
            <Form.Item label="表注释"><Input value={editingTable.comment} onChange={(e) => updateTable(editingTable.id, { comment: e.target.value })} /></Form.Item>
          </Form></Panel>
          <Panel header={'字段定义 (' + editingTable.columns.length + ')'} key="columns">
            <Alert message="变更类型说明：ADD = 新增字段（绿色） MODIFY = 修改字段（橙色） | 不支持删除列操作" type="info" showIcon style={{ marginBottom: 16 }} />
            <Space style={{ marginBottom: 16 }}><Button type="primary" size="small" icon={<PlusOutlined />} onClick={() => addColumn(editingTable.id)}>添加新字段</Button></Space>
            <Table dataSource={editingTable.columns} columns={columnColumns} rowKey="id" size="small" pagination={false} scroll={{ y: 220 }} />
            <Card size="small" title="新增字段表单" style={{ marginTop: 16 }}><Form form={form} layout="vertical" size="small">
              <Row gutter={12}><Col span={10}><Form.Item name="newName" label="字段名"><Input placeholder="column_name" /></Form.Item></Col><Col span={8}><Form.Item name="newType" label="类型" initialValue="VARCHAR"><Select>{MYSQL_TYPES.map(t => <Option key={t} value={t}>{t}</Option>)}</Select></Form.Item></Col><Col span={6}><Form.Item name="newLength" label="长度"><Input type="number" placeholder="255" /></Form.Item></Col></Row>
              <Row gutter={12} align="middle"><Col span={6}><Form.Item name="newNullable" valuePropName="checked" label="可空" initialValue={true}><Switch size="small" /></Form.Item></Col><Col span={18}><Form.Item name="newComment" label="注释"><Input /></Form.Item></Col></Row>
              <Button type="primary" size="small" onClick={() => { form.validateFields().then((values: any) => { const newCol: ColumnDef = { id: genId(), name: values.newName, type: values.newType, length: values.newLength, nullable: values.newNullable, primaryKey: false, autoIncrement: false, unique: false, comment: values.newComment, changeType: 'ADD', isNew: true }; updateTable(editingTable.id, { columns: [...editingTable.columns, newCol] }); form.resetFields(); message.success('字段已添加'); }); }}>添加字段</Button>
            </Form></Card>
          </Panel>
          <Panel header="快捷操作" key="quick"><Card size="small" title="添加常用字段模板"><Space wrap>
            <Button size="small" onClick={() => addCommonFields(editingTable.id, 'audit')}>审计字段（created_at, updated_at, created_by, updated_by）</Button>
            <Button size="small" onClick={() => addCommonFields(editingTable.id, 'logic_delete')}>逻辑删除（deleted）</Button>
            <Button size="small" onClick={() => addCommonFields(editingTable.id, 'tenant')}>多租户（tenant_id）</Button>
          </Space></Card></Panel>
        </Collapse>)}
      </Drawer>
      <Modal title={sqlMode === 'create' ? '生成建表 SQL' : '生成变更 SQL'} open={sqlModalVisible} onCancel={() => setSqlModalVisible(false)} width={800} okButtonProps={{ style: { display: 'none' } }}>
        {sqlMode === 'alter' && tables.some(t => !t.isNew) && (<Alert message="ALTER TABLE 会锁表，大表请使用「无锁变更」功能执行！建议在业务低峰期操作" type="warning" showIcon style={{ marginBottom: 16 }} />)}
        <TextArea value={generatedSql} readOnly rows={20} style={{ fontFamily: 'monospace', fontSize: 12 }} />
        <Divider /><Space>
          <Button type="primary" onClick={() => { navigator.clipboard.writeText(generatedSql); message.success('已复制到剪贴板'); }}>复制 SQL</Button>
          <Button onClick={() => { const blob = new Blob([generatedSql], { type: 'text/plain' }); const url = URL.createObjectURL(blob); const a = document.createElement('a'); a.href = url; a.download = 'schema_' + (sqlMode === 'create' ? 'create' : 'alter') + '_' + Date.now() + '.sql'; a.click(); }}>下载 SQL 文件</Button>
        </Space>
      </Modal>
      <Modal title="从SQL粘贴导入表结构" open={importModalVisible} onCancel={() => setImportModalVisible(false)} onOk={handleImportSql} okText="导入" width={750}>
        <Alert message="如何获取建表语句？" description={<div>在数据库中执行：<code style={{ background: '#f0f5ff', padding: '4px 8px', borderRadius: 4, margin: '0 4px' }}>SHOW CREATE TABLE 你的表名</code><br /><br />支持批量导入多张表，每条 CREATE TABLE 语句以分号结尾</div>} type="info" showIcon style={{ marginBottom: 16 }} />
        <TextArea value={importSql} onChange={(e) => setImportSql(e.target.value)} rows={12} placeholder="粘贴 CREATE TABLE SQL 语句..." style={{ fontFamily: 'monospace', fontSize: 12 }} />
      </Modal>
    </div>
  );
};
export default SchemaDesignerPage;
